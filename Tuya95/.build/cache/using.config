
#
# configure project
#
CONFIG_PROJECT_NAME="Tuya95"
CONFIG_PROJECT_VERSION="1.0.0"
CONFIG_PROJECT_FRAMEWORK_BASE=y
# CONFIG_PROJECT_FRAMEWORK_ARDUINO is not set
CONFIG_FRAMEWORK_CHOICE="base"
# end of configure project

CONFIG_BOARD_ENABLE_LINUX=y
CONFIG_BOARD_ENABLE_T2=y
CONFIG_BOARD_ENABLE_T3=y
CONFIG_BOARD_ENABLE_T5AI=y
CONFIG_BOARD_ENABLE_ESP32=y
CONFIG_BOARD_ENABLE_LN882H=y
CONFIG_BOARD_ENABLE_BK7231X=y
# CONFIG_BOARD_CHOICE_LINUX is not set
CONFIG_PLATFORM_CHOICE="T5AI"
CONFIG_LITTLE_END=1
CONFIG_ENABLE_WIFI=y
CONFIG_ENABLE_BLUETOOTH=y
CONFIG_ENABLE_GPIO=y
CONFIG_ENABLE_I2C=y
CONFIG_ENABLE_SPI=y
CONFIG_ENABLE_PWM=y
CONFIG_ENABLE_UART=y
CONFIG_ENABLE_EXT_RAM=y
CONFIG_MBEDTLS_CONFIG_FILE="tuya_tls_config.h"
CONFIG_OPERATING_SYSTEM=98
CONFIG_CHIP_CHOICE="T5AI"
CONFIG_BOARD_CHOICE="TUYA_T5AI_BOARD"
CONFIG_BOARD_CONFIG=y
CONFIG_AUDIO_CODEC_NAME="audio"
CONFIG_BUTTON_NAME="button1"
# CONFIG_ENABLE_CAMERA is not set
# CONFIG_BOARD_CHOICE_T2 is not set
CONFIG_ENABLE_ADC=y
CONFIG_ENABLE_TIMER=y
CONFIG_ENABLE_WATCHDOG=y
# CONFIG_BOARD_CHOICE_T3 is not set
CONFIG_ENABLE_HCI=y
CONFIG_ENABLE_RTC=y
CONFIG_ENABLE_FLASH=y
CONFIG_TUYA_FLASH_TYPE_MAX_PARTITION_NUM=10
CONFIG_ENABLE_PM=y
CONFIG_ENABLE_WAKEUP=y
CONFIG_ENABLE_PINMUX=y
CONFIG_BOARD_CHOICE_T5AI=y
CONFIG_PLATFORM_T5=y
CONFIG_ENABLE_BIG_CORE=y
CONFIG_ENABLE_QSPI=y
CONFIG_ENABLE_MCU8080=y
CONFIG_ENABLE_TOUCH=y
CONFIG_ENABLE_MEDIA=y
CONFIG_ENABLE_DVP=y
CONFIG_ENABLE_DMA2D=y
CONFIG_ENABLE_RGB=y
CONFIG_ENABLE_PIN2FUNC=y
CONFIG_ENABLE_SMP=y
CONFIG_ENABLE_T5AI_OS_SERVICE=y
CONFIG_BOARD_CHOICE_TUYA_T5AI_BOARD=y
# CONFIG_TUYA_T5AI_BOARD_VERSION_101 is not set
CONFIG_TUYA_T5AI_BOARD_VERSION_102=y
CONFIG_TUYA_T5AI_BOARD_EX_MODULE_NONE=y
# CONFIG_TUYA_T5AI_BOARD_EX_MODULE_35565LCD is not set
# CONFIG_TUYA_T5AI_BOARD_EX_MODULE_EYES is not set
# CONFIG_TUYA_T5AI_BOARD_EX_MODULE_096_OLED is not set
# CONFIG_BOARD_CHOICE_TUYA_T5AI_EVB is not set
# CONFIG_BOARD_CHOICE_TUYA_T5AI_CORE is not set
# CONFIG_BOARD_CHOICE_T5AI_MINI is not set
# CONFIG_BOARD_CHOICE_T5AI_MOJI_1_28 is not set
# CONFIG_BOARD_CHOICE_TUYA_T5AI_POCKET is not set
# CONFIG_BOARD_CHOICE_ATK_T5AI_MINI_BOARD is not set
# CONFIG_BOARD_CHOICE_WAVESHARE_T5AI_TOUCH_AMOLED_1_75 is not set
# CONFIG_BOARD_CHOICE_T5AI_OTTO is not set
# CONFIG_BOARD_CHOICE_TUYA_T5AI_PIXEL is not set
# CONFIG_BOARD_CHOICE_TUYA_T5AI_DESKTOP_ROBOT is not set
# CONFIG_BOARD_CHOICE_TUYA_T5AI_DOG is not set
# CONFIG_BOARD_CHOICE_TUYA_T5AI_EINK_NFC is not set
# CONFIG_BOARD_CHOICE_ESP32 is not set
CONFIG_DISPLAY_NAME="display"
# CONFIG_BOARD_CHOICE_LN882H is not set
# CONFIG_BOARD_CHOICE_BK7231X is not set

#
# configure tuyaopen
#
# CONFIG_ENABLE_SERIAL_CLI_CMD is not set
CONFIG_SERIAL_CLI_STACK_SIZE=3072

#
# configure tuya cloud service
#
CONFIG_TUYA_SECURITY_LEVEL=1
CONFIG_ENABLE_BT_SERVICE=y
CONFIG_ENABLE_BT_NETCFG=y
CONFIG_ENABLE_BT_CTRL=y
CONFIG_BT_ADV_INTERVAL_MIN=30
CONFIG_BT_ADV_INTERVAL_MAX=60
CONFIG_BT_REMOTE_CTRL_SCAN_INTERVAL=30
CONFIG_BT_REMOTE_CTRL_SCAN_WINDOWS=10
CONFIG_ENABLE_NIMBLE=y
CONFIG_TUYA_HS_BLE_HOST_TASK_PRIORITY=9
CONFIG_TUYA_HS_BLE_HOST_STACK_SIZE=5120
# end of configure tuya cloud service

#
# configure tuya AI
#

#
# AI Agent Config
#
CONFIG_AI_INPUT_STACK_SIZE=4608
CONFIG_AI_INPUT_RINGBUF_SIZE=65536
CONFIG_AI_INPUT_BUF_SIZE=6144
CONFIG_AI_OUTPUT_STACK_SIZE=4096
CONFIG_AI_OUTPUT_RINGBUF_SIZE=65536
CONFIG_AI_OUTPUT_BUF_SIZE=5120
# end of AI Agent Config

#
# AI Protocol Config
#
CONFIG_ENABLE_AI_MONITOR=y
CONFIG_AI_MAX_FRAGMENT_LENGTH=10240
# CONFIG_ENABLE_AI_PROTO_DEBUG is not set
CONFIG_AI_BIZ_TASK_DELAY=10
CONFIG_AI_SESSION_MAX_NUM=2
CONFIG_AI_BIZ_MAX_NUM=5
CONFIG_AI_MAX_ATTR_NUM=10
CONFIG_AI_PING_TIMEOUT=6
CONFIG_AI_HEARTBEAT_INTERVAL=120
CONFIG_AI_PACKET_SECURITY_LEVEL=4
CONFIG_AI_CLIENT_STACK_SIZE=4096
CONFIG_AI_READ_SOCKET_BUF_SIZE=0
CONFIG_AI_WRITE_SOCKET_BUF_SIZE=8192
CONFIG_AI_DL_IMAGE_UNIT_SIZE=4096
CONFIG_AI_HEAP_IN_PSRAM=y
# CONFIG_AI_STACK_IN_PSRAM is not set
CONFIG_AI_SEND_PKT_TIMEOUT=6
CONFIG_AI_VERSION=1
# end of AI Protocol Config

CONFIG_ENABLE_TUYA_CODEC=y
# CONFIG_ENABLE_TUYA_CODEC_OPUS is not set
# CONFIG_ENABLE_TUYA_CODEC_SPEEX is not set
# end of configure tuya AI

# CONFIG_ENABLE_AI_PLAYER is not set

#
# configure enable/disable liblwip
#
# CONFIG_ENABLE_LIBLWIP is not set
# end of configure enable/disable liblwip

#
# configure mbedtls
#
# CONFIG_ENABLE_MBEDTLS_DEBUG is not set
CONFIG_ENABLE_MBEDTLS_SSL_MAX_CONTENT_LEN=4096
# CONFIG_ENABLE_CUSTOM_CONFIG is not set
# end of configure mbedtls

#
# configure system parameter
#
CONFIG_STACK_SIZE_TIMERQ=4096
CONFIG_STACK_SIZE_WORK_QUEUE=5120
CONFIG_MAX_NODE_NUM_WORK_QUEUE=100
CONFIG_STACK_SIZE_MSG_QUEUE=4096
CONFIG_MAX_NODE_NUM_MSG_QUEUE=100
# end of configure system parameter

CONFIG_ENABLE_LIBLVGL=y
# CONFIG_LVGL_VERSION_8 is not set
CONFIG_LVGL_VERSION_9=y
# CONFIG_ENABLE_LVGL_OS_FREERTOS is not set
CONFIG_LVGL_ENABLE_TP=y
# CONFIG_ENABLE_LVGL_DEMO is not set
# CONFIG_ENABLE_LVGL_MONITOR is not set
# CONFIG_ENABLE_LVGL_ENCODER is not set
# CONFIG_ENABLE_LVGL_LODEPNG is not set
# CONFIG_ENABLE_LVGL_DUAL_DISP_BUFF is not set
CONFIG_LV_DRAW_BUF_PROPORTION_10=y
# CONFIG_LV_DRAW_BUF_PROPORTION_5 is not set
CONFIG_LV_DRAW_BUF_PARTS=10

#
# LVGL Font Configuration
#

#
# Montserrat Fonts with ASCII range (bpp = 4)
#
# CONFIG_LV_FONT_MONTSERRAT_8 is not set
# CONFIG_LV_FONT_MONTSERRAT_10 is not set
# CONFIG_LV_FONT_MONTSERRAT_12 is not set
CONFIG_LV_FONT_MONTSERRAT_14=y
CONFIG_LV_FONT_MONTSERRAT_16=y
# CONFIG_LV_FONT_MONTSERRAT_18 is not set
# CONFIG_LV_FONT_MONTSERRAT_20 is not set
# CONFIG_LV_FONT_MONTSERRAT_22 is not set
CONFIG_LV_FONT_MONTSERRAT_24=y
# CONFIG_LV_FONT_MONTSERRAT_26 is not set
# CONFIG_LV_FONT_MONTSERRAT_28 is not set
# CONFIG_LV_FONT_MONTSERRAT_30 is not set
# CONFIG_LV_FONT_MONTSERRAT_32 is not set
# CONFIG_LV_FONT_MONTSERRAT_34 is not set
# CONFIG_LV_FONT_MONTSERRAT_36 is not set
# CONFIG_LV_FONT_MONTSERRAT_38 is not set
# CONFIG_LV_FONT_MONTSERRAT_40 is not set
# CONFIG_LV_FONT_MONTSERRAT_42 is not set
# CONFIG_LV_FONT_MONTSERRAT_44 is not set
# CONFIG_LV_FONT_MONTSERRAT_46 is not set
# CONFIG_LV_FONT_MONTSERRAT_48 is not set

#
# Special Fonts
#
# CONFIG_LV_FONT_MONTSERRAT_28_COMPRESSED is not set
# CONFIG_LV_FONT_DEJAVU_16_PERSIAN_HEBREW is not set
# CONFIG_LV_FONT_SIMSUN_16_CJK is not set

#
# Pixel Perfect Monospace Fonts
#
CONFIG_LV_FONT_UNSCII_8=y
CONFIG_LV_FONT_UNSCII_16=y
# end of LVGL Font Configuration

#
# configure device driver
#
CONFIG_ENABLE_BUTTON=y
CONFIG_BUTTION_STACK_SIZE=2048
# CONFIG_ENABLE_BUTTON_2 is not set
CONFIG_ENABLE_LED=y
CONFIG_LED_NUM=1
CONFIG_LED_NAME="led"
CONFIG_ENABLE_AUDIO_CODECS=y
CONFIG_AUDIO_CODECS_NUM=1
CONFIG_ENABLE_AUDIO_AEC=y
CONFIG_ENABLE_DISPLAY=y
# CONFIG_ENABLE_DISPLAY_2 is not set
CONFIG_ENABLE_TP=y
# CONFIG_ENABLE_ENCODER is not set
# CONFIG_ENABLE_JOYSTICK is not set
# CONFIG_ENABLE_PMIC is not set
# CONFIG_ENABLE_IR is not set
# CONFIG_ENABLE_LEDS_PIXEL is not set
# CONFIG_ENABLE_IMU is not set
# end of configure device driver

# CONFIG_ENABLE_TUYA_P2P is not set
# CONFIG_ENABLE_MICROPYTHON is not set
# end of configure tuyaopen
